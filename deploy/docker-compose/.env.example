# ── Host Manager — environment variables ──────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to source control.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Public URL of the control plane (used in OAuth callbacks, agent bootstrap)
HOSTMGR_EXTERNAL_URL=https://localhost:443

# NATS WebSocket URL for agents (port 443, TLS 1.3)
HOSTMGR_NATS_URL=wss://localhost:443

# OpenBao address
HOSTMGR_OPENBAO_URL=http://openbao:8200

# OpenBao token (dev mode only; use AppRole or similar in production)
HOSTMGR_OPENBAO_DEV_TOKEN=dev-only-token

# ---------------------------------------------------------------------------
# Auth (ADR-007)
# ---------------------------------------------------------------------------

# OAuth allowlist — comma-separated, prefixed with provider name
# HOSTMGR_ALLOWED_USERS=github:joewxboy,google:joe@example.com
HOSTMGR_ALLOWED_USERS=github:your-github-username

# GitHub OAuth App (create at https://github.com/settings/developers)
HOSTMGR_AUTH_GITHUB_CLIENT_ID=
HOSTMGR_AUTH_GITHUB_CLIENT_SECRET_REF=secret/config/oauth/github_client_secret

# Google OAuth App (create at https://console.cloud.google.com)
HOSTMGR_AUTH_GOOGLE_CLIENT_ID=
HOSTMGR_AUTH_GOOGLE_CLIENT_SECRET_REF=secret/config/oauth/google_client_secret

# JWT signing key — Ed25519 seed stored in OpenBao
HOSTMGR_JWT_SIGNING_KEY_REF=secret/config/jwt_signing_key
HOSTMGR_JWT_TTL=28800   # 8 hours in seconds

# ---------------------------------------------------------------------------
# Agent
# ---------------------------------------------------------------------------

# Bootstrap token lifetime (seconds). Tokens are single-use.
HOSTMGR_BOOTSTRAP_TOKEN_TTL=300

# Default update trigger for new agents
HOSTMGR_UPDATE_TRIGGER=manual

# ---------------------------------------------------------------------------
# MCP client (optional enrichment — Phase 1.1)
# ---------------------------------------------------------------------------

# HOSTMGR_MCP_NETBOX_URL=https://netbox.local/mcp
# HOSTMGR_MCP_NETBOX_API_KEY=
HOSTMGR_MCP_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
RUST_LOG=info
