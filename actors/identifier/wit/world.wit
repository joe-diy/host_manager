/// Identifier — manages SSH-based endpoint identification.
/// Receives endpoint.{id}.identify, calls the identification capability
/// provider (SSH probe), stores result in OpenBao, publishes identified event.
package hostmgr:identifier@0.1.0;

world identifier {
    import wasmcloud:messaging/consumer@0.2.0;

    export wasmcloud:messaging/handler@0.2.0;
}
